# Gateway environment example (Render)
# Copy to .env for local tests, and set these in Render service/job env vars.

# Kong Docker image tag
KONG_DOCKER_TAG=kong:latest

# Kong DB mode
KONG_DATABASE=postgres

# Render Postgres credentials for Kong
KONG_PG_HOST=your-render-postgres-host
KONG_PG_PORT=5432
KONG_PG_DATABASE=your-render-postgres-database
KONG_PG_USER=your-render-postgres-user
KONG_PG_PASSWORD=your-render-postgres-password

# Optional auth upstream for automation scripts/docs
AUTH_PUBLIC_URL=https://your-auth-service.onrender.com

# Optional client origin for CORS
CLIENT_ORIGIN=https://your-client-domain.onrender.com
