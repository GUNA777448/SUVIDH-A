# Docker Environment Configuration
# Copy this file to .env.docker and update with your actual values

# Client Environment
CLIENT_PORT=3000

# API Gateway
API_GATEWAY_PORT=4009
API_GATEWAY_ENV=production

# Auth Service
AUTH_SERVICE_PORT=5001
AUTH_SERVICE_ENV=production

# Database Configuration
DATABASE_URL=postgresql://user:password@postgres:5432/suvidha_auth
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=suvidha_auth

# Redis Configuration
REDIS_URL=redis://redis:6379

# Application Keys (Replace with actual values for production)
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# API Configuration
VITE_API_BASE_URL=http://localhost:4009
VITE_AUTH_API_PREFIX=/api/v1/auth

# Service URLs in Docker Network
AUTH_SERVICE_URL=http://auth-service:5001
