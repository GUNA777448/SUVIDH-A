              "script": {
                "exec": [
                  "pm.test('Status is 404', function () { pm.response.to.have.status(404); });",
                  "const body = pm.response.json();",
                  "pm.test('Error code is USER_NOT_FOUND', function () {",
                  "  pm.expect(body.success).to.eql(false);",
                  "  pm.expect(body.error.code).to.eql('USER_NOT_FOUND');",
                  "});"
