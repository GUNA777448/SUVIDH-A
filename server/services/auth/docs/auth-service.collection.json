            }
          ]
        },
        {
          "name": "POST /api/v1/auth/login/otp - Success (Mobile)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifierType\": \"{{identifierType}}\",\n  \"identifierValue\": \"{{identifierValue}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login/otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login", "otp"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('OTP response envelope is valid', function () {",
                  "  pm.expect(body.success).to.eql(true);",
                  "  pm.expect(body.data.consumerId).to.be.a('string');",
                  "  pm.expect(body.data.otpExpiresAt).to.be.a('string');",
                  "});",
                  "if (body.data.otp) { pm.collectionVariables.set('otp', body.data.otp); }",
                  "pm.collectionVariables.set('identifierType', body.data.identifierType);",
                  "pm.collectionVariables.set('identifierValue', body.data.identifierValue);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
