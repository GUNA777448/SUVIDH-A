    {
      "name": "01 - Login OTP Request",
      "item": [
        {
          "name": "POST /api/v1/auth/login/otp - Invalid identifierType",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifierType\": \"X\",\n  \"identifierValue\": \"6300614592\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login/otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login", "otp"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', function () { pm.response.to.have.status(400); });",
                  "const body = pm.response.json();",
                  "pm.test('Error code is INVALID_IDENTIFIER', function () {",
                  "  pm.expect(body.success).to.eql(false);",
                  "  pm.expect(body.error.code).to.eql('INVALID_IDENTIFIER');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/auth/login/otp - User not found",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifierType\": \"C\",\n  \"identifierValue\": \"99999999\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login/otp",
