    {
      "name": "02 - Login OTP Verify",
      "item": [
        {
          "name": "POST /api/v1/auth/login/verify - Invalid OTP format",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifierType\": \"M\",\n  \"identifierValue\": \"6300614592\",\n  \"otp\": \"12\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login/verify",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login", "verify"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400', function () { pm.response.to.have.status(400); });",
                  "const body = pm.response.json();",
                  "pm.test('Error code is INVALID_OTP', function () {",
                  "  pm.expect(body.success).to.eql(false);",
                  "  pm.expect(body.error.code).to.eql('INVALID_OTP');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/auth/login/verify - Wrong OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifierType\": \"{{identifierType}}\",\n  \"identifierValue\": \"{{identifierValue}}\",\n  \"otp\": \"000000\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login/verify",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login", "verify"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401', function () { pm.response.to.have.status(401); });",
                  "const body = pm.response.json();",
                  "pm.test('OTP rejection code is returned', function () {",
                  "  pm.expect(body.success).to.eql(false);",
                  "  pm.expect(body.error.code).to.match(/^OTP_/);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/auth/login/verify - Success (Mobile)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "if (!pm.collectionVariables.get('otp')) {",
                  "  throw new Error('otp variable is empty. Run request OTP success test first.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('Token and user are present', function () {",
                  "  pm.expect(body.success).to.eql(true);",
                  "  pm.expect(body.data.tokenType).to.eql('Bearer');",
                  "  pm.expect(body.data.accessToken).to.be.a('string');",
                  "  pm.expect(body.data.user.consumerId).to.be.a('string');",
                  "});",
                  "pm.collectionVariables.set('accessToken', body.data.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifierType\": \"{{identifierType}}\",\n  \"identifierValue\": \"{{identifierValue}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login/verify",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login", "verify"]
            }
          }
        },
        {
          "name": "POST /api/v1/auth/login/verify - Reuse OTP should fail",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifierType\": \"{{identifierType}}\",\n  \"identifierValue\": \"{{identifierValue}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login/verify",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login", "verify"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 401', function () { pm.response.to.have.status(401); });",
                  "const body = pm.response.json();",
                  "pm.test('Reuse OTP rejected', function () {",
                  "  pm.expect(body.success).to.eql(false);",
                  "  pm.expect(body.error.code).to.eql('OTP_NOT_FOUND');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
