# Tunnel mode example for mobile testing.
# Replace VITE_API_BASE_URL with your gateway tunnel URL.

VITE_API_BASE_URL=https://your-gateway-tunnel-url.example
VITE_AUTH_API_PREFIX=/api/v1/auth
VITE_GAS_API_PREFIX=/api/v1/gas-distribution
VITE_PAYMENT_API_PREFIX=/api/v1/payments

# Optional direct service URLs (kept for compatibility with existing config)
VITE_AUTH_SERVICE_URL=http://localhost:4009
VITE_ELECTRICITY_SERVICE_URL=http://localhost:4001
VITE_GAS_SERVICE_URL=http://localhost:4002
VITE_WATER_SERVICE_URL=http://localhost:4003
VITE_WASTE_SERVICE_URL=http://localhost:4004
VITE_PAYMENT_SERVICE_URL=http://localhost:4005
